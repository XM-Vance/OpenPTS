{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "Backend Up",
      "datasource": "Prometheus",
      "targets": [{ "expr": "up{job=\"backend-health\"}", "legendFormat": "backend" }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Postgres Up",
      "datasource": "Prometheus",
      "targets": [{ "expr": "pg_up", "legendFormat": "postgres" }],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "stat",
      "title": "Postgres 活跃连接",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(pg_stat_activity_count)" }],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "宿主 CPU (1m load)",
      "datasource": "Prometheus",
      "targets": [{ "expr": "node_load1" }],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "容器 CPU 使用率",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"ptis-.*\"}[2m]))",
        "legendFormat": "{{name}}"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "type": "timeseries",
      "title": "容器内存 (MB)",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "container_memory_usage_bytes{name=~\"ptis-.*\"} / 1024 / 1024",
        "legendFormat": "{{name}}"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "type": "timeseries",
      "title": "Postgres QPS",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "rate(pg_stat_database_xact_commit{datname=\"ptis\"}[1m]) + rate(pg_stat_database_xact_rollback{datname=\"ptis\"}[1m])",
        "legendFormat": "tx/sec"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "type": "timeseries",
      "title": "Postgres 死锁数",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "increase(pg_stat_database_deadlocks{datname=\"ptis\"}[5m])",
        "legendFormat": "deadlocks/5m"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ptis-v2"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "ptis-v2 概览",
  "uid": "ptis-v2-overview",
  "version": 1
}
