# 电力交易信息平台部署环境变量样例。
# 用法：
#   1) 复制为 .env：cp .env.example .env
#   2) 修改 JWT_SECRET / POSTGRES_PASSWORD 等敏感项
#   3) docker compose up -d --build
# docker-compose.yml 通过 ${VAR:-default} 语法读取本文件。

# ─── PostgreSQL ───
POSTGRES_USER=ptis
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ptis
# 后端连接串（compose 内部用 postgres:5432；本地直连用 localhost:5432）
# DATABASE_URL=postgres://ptis:change_me_strong_password@localhost:5432/ptis?sslmode=disable
# 只读副本（可选；配置后读请求分流到副本，副本不可用不阻塞启动）
# DATABASE_REPLICA_URL=

# ─── HTTP ───
# nginx 对外端口（生产场景建议放在反代后面、用 443）
HTTP_PORT=80

# ─── Backend ───
ENVIRONMENT=production
LOG_LEVEL=info
# 必填，长度 >= 32 字符；可用 `openssl rand -base64 48` 生成
JWT_SECRET=please...hars
# 登录态有效期(小时)。P1-8 起登录走 httpOnly Cookie,默认从 24 收紧到 8
JWT_TTL_HOURS=8
# CORS 生产白名单（逗号分隔，留空则 AllowAllOrigins + 无 credentials）
ALLOWED_ORIGINS=https://your-domain.com

# ─── MinIO 对象存储（合同/附件 PDF 等）───
MINIO_ACCESS_KEY=ptisadmin
MINIO_SECRET_KEY=change_me_strong_minio_password
MINIO_BUCKET=ptis
# 本地直连 MinIO 时用（compose 内部固定 minio:9000）
# MINIO_ENDPOINT=localhost:9000
# MINIO_USE_SSL=false

# ─── 文档解析服务 docling ───
# 视觉 OCR（PDF/图片识别）：智谱开放平台密钥（https://open.bigmodel.cn）。
# 解析 PDF/图片必填；只用 Excel/CSV 直读可不填。仅放此处、不入代码。
ZHIPU_API_KEY=your_zhipu_api_key_here
# 以下一般用默认值即可（与 docker-compose.yml 默认一致）
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_VISION_MODEL=glm-4v-flash
#
# 结构化字段提取（合同/结算单的甲乙方、电量、电价、套餐…）：优先用 DeepSeek，
# 未配置时自动回退到上面的 GLM。建议配上，提取更准。https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 以下一般用默认值即可
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_TEXT_MODEL=deepseek-chat
# GLM 文本模型（DeepSeek 回退时用）
# ZHIPU_TEXT_MODEL=glm-4-flash

# ─── 文档解析上传限制（docling-service）───
# MAX_UPLOAD_BYTES=10485760

# ─── HTTPS（仅当用 Caddy 部署时需要）───
# PTIS_DOMAIN=ptis.example.com
# ACME_EMAIL=ops@example.com

# ─── 监控告警（仅当启用监控栈时需要）───
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001
# GRAFANA_USER=admin
# 飞书告警 webhook（alert-webhook-proxy 转译；WARNING 与 CRITICAL 可分开，不填则不推送飞书）
# FEISHU_WEBHOOK_WARNING=
# FEISHU_WEBHOOK_CRITICAL=
# 邮件告警（alertmanager.yml 经 envsubst 渲染；不配则连本地 SMTP 失败、邮件告警不生效）
# SMTP_FROM=alert@ptis.local
# SMTP_HOST=mail.ptis.local:25
# SMTP_USER=
# SMTP_PASSWORD=
# ALERT_EMAIL_TO=ops@ptis.local
# GRAFANA_PASSWORD=please_change_me

# ─── 本地开发（不走 docker-compose）使用以下值 ───
# 替换 docker-compose 默认值后取消注释直接 export
# PORT=8080
# DATABASE_URL=postgres://ptis:ptis_dev@localhost:5432/ptis?sslmode=disable
# DOCLING_SERVICE_URL=http://localhost:8300   # Go 网关访问 docling 文档解析服务
