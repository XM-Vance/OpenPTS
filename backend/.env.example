# backend 本地开发环境变量
# 复制为 .env 后修改敏感项：cp .env.example .env

# 服务端口
PORT=8080
# 环境：development / production
ENVIRONMENT=development
LOG_LEVEL=debug

# PostgreSQL（本地开发）
DATABASE_URL=postgres://ptis:your_password_here@localhost:5432/ptis?sslmode=disable
# 只读副本（可选）
# DATABASE_REPLICA_URL=postgres://ptis:your_password_here@localhost:5433/ptis?sslmode=disable

# 文档解析服务（docling，可选；不配则文档解析端点不可用）
# DOCLING_SERVICE_URL=http://localhost:8300

# JWT（至少 32 字符，生产环境必须更换）
# 生成方式：openssl rand -base64 48
JWT_SECRET=dev-only-insecure-secret-do-not-use-in-prod
JWT_TTL_HOURS=24

# CORS 白名单（生产环境必填，逗号分隔）
# ALLOWED_ORIGINS=https://your-domain.com

# MinIO 对象存储
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=ptisadmin
# MINIO_SECRET_KEY=your_minio_password
# MINIO_BUCKET=ptis
# MINIO_USE_SSL=false
